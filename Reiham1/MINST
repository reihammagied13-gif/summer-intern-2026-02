import pandas as pd

# Load training data
train = pd.read_csv(r"C:\Users\GM\Desktop\MINST\mnist_train.csv")

# Load testing data
test = pd.read_csv(r"C:\Users\GM\Desktop\MINST\mnist_test.csv")

# Features and labels
X_train = train.iloc[:, 1:].values
y_train = train.iloc[:, 0].values

X_test = test.iloc[:, 1:].values
y_test = test.iloc[:, 0].values

rf_model = RandomForestClassifier(random_state=42)
